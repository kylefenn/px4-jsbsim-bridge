  <!-- Initial attitude (level on ground) -->
  <phi unit="DEG">0.0</phi>
  <theta unit="DEG">0.0</theta>
  <psi unit="DEG">0.0</psi>

  <!-- Initial angular rates -->
  <p unit="RAD/SEC">0.0</p>
