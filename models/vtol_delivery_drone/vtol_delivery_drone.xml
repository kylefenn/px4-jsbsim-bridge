  <aerodynamics>








    <function name="aero/coefficient/CL0">


      <description>Lift coefficient at zero angle of attack (disabled for hover)</description>


      <value>0.0</value>


    </function>



    <function name="aero/coefficient/CLalpha">


      <description>Lift curve slope - disabled for hover</description>


      <product>


        <value>0.0</value>


        <property>aero/alpha-rad</property>


      </product>


    </function>



    <function name="aero/coefficient/CL">


      <description>Total lift coefficient</description>


      <sum>


        <property>aero/coefficient/CL0</property>


        <property>aero/coefficient/CLalpha</property>


      </sum>


    </function>




    <function name="aero/coefficient/CD0">


      <description>Parasitic drag coefficient</description>


      <value>0.025</value>


    </function>



    <function name="aero/coefficient/CDi">


      <description>Induced drag coefficient (CL^2 / pi*AR*e)</description>


      <product>


        <property>aero/coefficient/CL</property>


        <property>aero/coefficient/CL</property>


        <value>0.035</value>


      </product>


    </function>



    <function name="aero/coefficient/CD">


      <description>Total drag coefficient</description>


      <sum>


        <property>aero/coefficient/CD0</property>


        <property>aero/coefficient/CDi</property>


      </sum>


    </function>




    <function name="aero/coefficient/CYbeta">


      <description>Side force due to sideslip</description>


      <product>


        <value>-0.4</value>


        <property>aero/beta-rad</property>


      </product>


    </function>




    <function name="aero/coefficient/Cm0">


      <description>Pitching moment at zero lift (disabled for hover - no wing moment)</description>


      <value>0.0</value>


    </function>



    <function name="aero/coefficient/Cmalpha">


      <description>Pitch stiffness (per radian) - negative = stable</description>


      <product>


        <value>-1.2</value>


        <property>aero/alpha-rad</property>


      </product>


    </function>



    <function name="aero/coefficient/Cmq">


      <description>Pitch damping</description>


      <product>


        <value>-15.0</value>


        <property>velocities/q-rad_sec</property>


        <property>metrics/cbarw-ft</property>


        <quotient>


          <value>1.0</value>


          <max>


            <property>velocities/vt-fps</property>


            <value>1.0</value>


          </max>


        </quotient>


      </product>


    </function>



    <function name="aero/coefficient/CmVtail">


      <description>V-tail elevator (ruddervator) effect on pitch</description>


      <product>


        <value>-0.8</value>


        <sum>


          <property>fcs/vtail-left-pos-norm</property>


          <property>fcs/vtail-right-pos-norm</property>


        </sum>


        <value>0.5</value>


      </product>


    </function>



    <function name="aero/coefficient/Cm">


      <description>Total pitching moment coefficient</description>


      <sum>


        <property>aero/coefficient/Cm0</property>


        <property>aero/coefficient/Cmalpha</property>


        <property>aero/coefficient/Cmq</property>


        <property>aero/coefficient/CmVtail</property>


      </sum>


    </function>




    <function name="aero/coefficient/Clp">


      <description>Roll damping</description>


      <product>


        <value>-0.5</value>


        <property>velocities/p-rad_sec</property>


        <property>metrics/bw-ft</property>


        <quotient>


          <value>1.0</value>


          <max>


            <property>velocities/vt-fps</property>


            <value>1.0</value>


          </max>


        </quotient>


      </product>


    </function>



    <function name="aero/coefficient/Clbeta">


      <description>Dihedral effect</description>


      <product>


        <value>-0.1</value>


        <property>aero/beta-rad</property>


      </product>


    </function>



    <function name="aero/coefficient/ClAileron">


      <description>Aileron roll control</description>


      <product>


        <value>0.15</value>


        <difference>


          <property>fcs/aileron-right-pos-norm</property>


          <property>fcs/aileron-left-pos-norm</property>


        </difference>


      </product>


    </function>



    <function name="aero/coefficient/Cl">


      <description>Total rolling moment coefficient</description>


      <sum>


        <property>aero/coefficient/Clp</property>


        <property>aero/coefficient/Clbeta</property>


        <property>aero/coefficient/ClAileron</property>


      </sum>


    </function>




    <function name="aero/coefficient/Cnr">


      <description>Yaw damping</description>


      <product>


        <value>-0.15</value>


        <property>velocities/r-rad_sec</property>


        <property>metrics/bw-ft</property>


        <quotient>


          <value>1.0</value>


          <max>


            <property>velocities/vt-fps</property>


            <value>1.0</value>


          </max>


        </quotient>


      </product>


    </function>



    <function name="aero/coefficient/Cnbeta">


      <description>Weathercock stability (V-tail)</description>


      <product>


        <value>0.12</value>


        <property>aero/beta-rad</property>


      </product>


    </function>



    <function name="aero/coefficient/CnVtail">


      <description>V-tail rudder (ruddervator) effect on yaw</description>


      <product>


        <value>0.08</value>


        <difference>


          <property>fcs/vtail-left-pos-norm</property>


          <property>fcs/vtail-right-pos-norm</property>


        </difference>


      </product>


    </function>



    <function name="aero/coefficient/Cn">


      <description>Total yawing moment coefficient</description>


      <sum>


        <property>aero/coefficient/Cnr</property>


        <property>aero/coefficient/Cnbeta</property>


        <property>aero/coefficient/CnVtail</property>


      </sum>


    </function>







