<?xml version="1.0"?>
<!--
  VTOL Delivery Drone - 10" Lift Propeller
  Designed for efficient hover at 9.8kg with 8 motors
  Target: ~12.5N per motor at hover (96N total / 8 = 12N each)
  Max: ~25N per motor for 2:1 thrust-to-weight at MTOW
-->
<propeller name="VTOL_10inch_Lift" version="1.1">
  <!-- Moment of inertia about propeller axis -->
  <!-- I = (1/12) * m * D^2, for 10" prop ~40g -->
  <ixx unit="KG*M2">2.15e-04</ixx>

  <!-- Propeller diameter -->
  <diameter unit="IN">10.0</diameter>

  <!-- Number of blades -->
  <numblades>2</numblades>

  <!-- Fixed pitch propeller (0 = fixed, 1 = constant speed) -->
  <constspeed>0</constspeed>

